{
  "expo": {
    "name": "FinPilot",
    "slug": "FinPilot",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "finpilot",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.funnyskillz.finpilot",
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Allow FinPilot to use Face ID to unlock your financial documents.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.funnyskillz.finpilot",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow FinPilot to use Face ID to unlock your financial documents."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow FinPilot to scan financial documents.",
          "photosPermission": "Allow FinPilot to import document photos."
        }
      ],
      "expo-secure-store",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "aiBaseUrl": "http://localhost:8787",
      "eas": {
        "projectId": "07126557-2031-4b4e-86ba-ded22804fa82"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/07126557-2031-4b4e-86ba-ded22804fa82"
    }
  }
}
